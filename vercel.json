{
  "version": 2,
  "buildCommand": "pnpm build",
  "installCommand": "pnpm install",
  "nodeVersion": "20.x",
  "routes": [
    {
      "src": "/api/trpc(.*)",
      "dest": "/dist/index.js",
      "methods": ["GET", "POST", "PUT", "DELETE", "PATCH"]
    },
    {
      "src": "/assets/(.*)",
      "dest": "/dist/public/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/dist/public/index.html"
    }
  ]
}
